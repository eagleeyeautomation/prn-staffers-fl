{
  "framework": "nextjs",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm build",
  "github": {
    "enabled": true,
    "autoAlias": true
  },
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.prnstaffersfl.com"
        }
      ],
      "destination": "https://prnstaffersfl.com/$1",
      "permanent": true
    }
  ]
}
